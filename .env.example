# Copy to .env and fill in before running `npx expo start`.
#
# LAN IP note: when you run the app on a physical phone via Expo Go,
# "localhost" points to the phone, not your Mac. Use your Mac's LAN IP
# (shown in the Expo CLI output), e.g. http://192.168.1.6:8000.
EXPO_PUBLIC_API_URL=http://localhost:8000

# From supabase.com -> Project -> Settings -> API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
